<% command_name, description, editor_version = prompt_command %>

<lexxy-prompt-item search="<%= description %> <%= command_name %>">
  <template type="menu">
    <code><%= command_name %></code> <%= description %>
  </template>
  <template type="editor">
    <%= editor_version.gsub(/ +$/, "&nbsp;").html_safe %>
  </template>
</lexxy-prompt-item>
